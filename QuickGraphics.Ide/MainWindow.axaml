<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="QuickGraphics.Ide.MainWindow"
        Title="QuickGraphics.Ide">

    <Grid x:Name="MainGrid" RowDefinitions="Auto,*" ColumnDefinitions="2*,*">

        <Button Grid.ColumnSpan="2" Margin="5" Click="RunButton_Click" HorizontalAlignment="Center">Compile and run</Button>

    </Grid>
</Window>
