<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="QuickGraphics.Ide.MainWindow"
        Title="QuickGraphics.Ide">

    <Grid RowDefinitions="Auto,*">
        <Button Margin="5" Click="RunButton_Click" HorizontalAlignment="Center">Compile and run</Button>

        <Grid Grid.Row="1" Background="#5d6b99">
            <Grid x:Name="MainGrid" Margin="10" ColumnDefinitions="*">
                <GridSplitter x:Name="Splitter" Grid.Column="1" ResizeDirection="Columns" Background="#5d6b99" IsVisible="True" />
            </Grid>
        </Grid>
    </Grid>
</Window>
